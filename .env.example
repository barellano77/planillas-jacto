# Backend base URL used by the frontend when it does NOT run on the same origin as the API.
# Leave empty for normal web deploys (single-process fullstack: frontend + /api on the same server).
#
# Required for the Android app in "bundled" mode (web assets packaged inside the APK): set this to
# your published app's public URL so the native WebView's fetch() calls reach the real backend
# instead of the local file/WebView origin. Example:
# VITE_API_BASE_URL=https://mi-app.dominio.com
VITE_API_BASE_URL=
